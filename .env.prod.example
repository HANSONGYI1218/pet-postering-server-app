# Runtime DB (PgBouncer/Pooler)
# 참고: Prisma는 Pooler 사용 시 prepared statements 비활성화를 위해 pgbouncer=true 필요
# connection_limit=1 권장(트랜잭션 풀링 모드)
DATABASE_URL="postgresql://postgres.qkfxepailunymumznwdu:U3yqZFbdNMq9ZoXT@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"

# Migration 전용(직접 연결, 5432)
# Supabase 콘솔의 DB 호스트(POOLER 아님)로 교체하세요.
# 예) postgresql://<USER>:<PASSWORD>@<DIRECT_DB_HOST>:5432/postgres?sslmode=require
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@DIRECT_DB_HOST:5432/postgres?sslmode=require"

# App
PORT="3000"
NODE_ENV="production"

# JWT
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="14d"

# Kakao OAuth
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
KAKAO_REDIRECT_URI="https://YOUR_DOMAIN/auth/kakao/callback"
KAKAO_LOGOUT_REDIRECT_URI="https://YOUR_DOMAIN/auth/logout/callback"

# Uploads (S3)
UPLOADS_BUCKET=""
UPLOADS_REGION="ap-northeast-2"
UPLOADS_CDN_DOMAIN=""
UPLOADS_MAX_SIZE=""
UPLOADS_URL_EXPIRES_IN=""

# Tips
# - 외부 DB만 사용할 때 docker-compose.prod.yml로 앱만 기동: 
#   docker compose -f docker-compose.prod.yml up -d --no-deps app
# - 마이그레이션은 CI/배포 훅에서: 
#   npx prisma migrate deploy --schema=./prisma/schema.prisma
